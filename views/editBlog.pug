doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    title Edit Blog | Admin
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body.bg-light
    .container.py-5
      .row.justify-content-center
        .col-md-8
          .card.shadow-sm
            .card-body.p-4
              h2.mb-4 🛠️ Edit Blog Content
              form(method="POST" action=`/blog/edit/${blog._id}`)
                .mb-3
                  label.form-label.fw-bold Title
                  input.form-control(name="title" type="text" value=blog.title required)
                
                .mb-3
                  label.form-label.fw-bold Content
                  textarea.form-control(name="description" rows="10" required)= blog.description
                
                .d-flex.gap-2
                  button.btn.btn-primary(type="submit") 
                    | Save Changes
                  a.btn.btn-outline-secondary(href="/adminBlogs") 
                    | Cancel