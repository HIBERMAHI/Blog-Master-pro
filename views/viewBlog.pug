doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    title #{blog.title} | Review
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body.bg-light
    .container.py-5
      .row.justify-content-center
        .col-md-8
          .card.shadow-sm
            .card-body
              h1.display-5 #{blog.title}
              p.text-muted Submitted by: #{blog.author.firstName} #{blog.author.lastName}
              hr
              //- This displays the full content of the blog
              div.blog-content.mb-4(style="white-space: pre-wrap;")
                | #{blog.description}
              
              .d-flex.gap-2
                //- Back to Dashboard
                a.btn.btn-secondary(href="/adminBlogs") Back to List
                
                //- Quick Actions
                form(method="POST" action=`/blog/status/${blog._id}`)
                  input(type="hidden" name="status" value="approved")
                  button.btn.btn-success(type="submit") Approve Now