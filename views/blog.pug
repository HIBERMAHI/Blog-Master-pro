doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title} | Blog-Master-Pro
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet"  href="/css/blog.css")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
    style.
      body { background-color: #f8f9fa; }
      .blog-card { border: none; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
      .btn-submit { background-color: #2c3e50; color: white; border-radius: 8px; }
      .btn-submit:hover { background-color: #1a252f; color: white; }
      .status-pending { color: #f39c12; font-weight: bold; }
      .status-approved { color: #27ae60; font-weight: bold; }
      .status-rejected { color: #e74c3c; font-weight: bold; }

  body
    //- Navigation with Admin logic
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.mb-5
      .container
        a.navbar-brand(href="/") FASHION PORTAL
        .navbar-nav.ms-auto
          a.nav-link(href="/fashionFeed") Fashion Feed
          if user && user.role === 'admin'
            a.nav-link.text-warning(href="/adminBlogs") 🛡️ Admin Dashboard
          a.nav-link.text-danger(href="/logout") Logout

    .container
      .row.justify-content-center
        .col-md-10
          .card.blog-card.mb-5
            .card-body.p-5
              h2.text-center.mb-4 ✍️ Write New Blog
              p.text-center.text-muted.mb-4 Welcome, **#{user.firstName}**. Your post will be sent to the Admin for approval.

              //- Flash Messages
              if success_msg && success_msg.length > 0
                .alert.alert-success.alert-dismissible.fade.show(role="alert")
                  | #{success_msg}
                  button.btn-close(type="button" data-bs-dismiss="alert")

              if error_msg && error_msg.length > 0
                .alert.alert-danger.alert-dismissible.fade.show(role="alert")
                  | #{error_msg}
                  button.btn-close(type="button" data-bs-dismiss="alert")

              //- The Blog Form (Date input removed)
              form(action="/blog" method="POST")
                .mb-4
                  label.form-label.fw-bold(for="title") Blog Title
                  input#title.form-control.form-control-lg(name="title" type="text" placeholder="What's on your mind?" required)
                
                .mb-4
                  label.form-label.fw-bold(for="description") Content
                  textarea#description.form-control(name="description" rows="6" placeholder="Start writing your story here..." required)

                .d-grid.gap-2
                  button.btn.btn-submit.btn-lg(type="submit") 
                    i.fas.fa-paper-plane.me-2
                    | Submit for Approval

          //- UPDATED SECTION: Displaying Submissions
          .card.blog-card
            .card-body
              h4.mb-4 📜 My Submissions
              if myBlogs && myBlogs.length > 0
                table.table.table-hover
                  thead.table-light
                    tr
                      th Title
                      th Date Submitted
                      th Status
                  tbody
                    each blog in myBlogs
                      tr
                        td.fw-bold #{blog.title}
                        td #{new Date(blog.createdAt).toLocaleString()}
                        td
                          if blog.approveStatus === 'pending'
                            span.status-pending ⏳ Pending
                          else if blog.approveStatus === 'approved'
                            span.status-approved ✅ Approved
                          else
                            span.status-rejected ❌ Rejected
              else
                p.text-muted You haven't submitted any blogs yet.

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")